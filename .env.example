# Optional: replace the default Amoy RPC (https://rpc-amoy.polygon.technology) if it is slow or blocked.
# Examples (use your own keys/URLs):
# VITE_POLYGON_AMOY_RPC=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
# VITE_POLYGON_AMOY_RPC=https://polygon-amoy.infura.io/v3/YOUR_KEY

# Optional: transaction / token-decimal logs in production (`npm run build`). In dev, logs are on by default.
# Or in the browser: localStorage.setItem('flux-swap-dev-logs','1')
# VITE_FLUX_SWAP_DEV_LOGS=true
